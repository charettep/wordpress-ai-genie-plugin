# AI Content Forge local environment template
#
# This file is committed. Your local `.env` is gitignored.
# Local setup scripts read this template, then read/update `.env`.
# Leave values blank to be prompted interactively by helper scripts.
# `scripts/docker-setup.sh` auto-generates secure random MariaDB credentials
# and names when corresponding fields are blank.

# Cloudflare + remote Ollama
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_UUID=
CLOUDFLARE_TUNNEL_DOMAIN=
OLLAMA_PUBLIC_HOSTNAME=
CLOUDFLARE_ACCESS_APP_NAME=
CLOUDFLARE_ACCESS_APP_ID=
CLOUDFLARE_SERVICE_TOKEN_NAME=
CLOUDFLARE_SERVICE_TOKEN_ID=
CLOUDFLARE_SERVICE_TOKEN_DURATION=
CLOUDFLARE_ACCESS_POLICY_ID=
CLOUDFLARE_ACCESS_HEADER_NAME=
CLOUDFLARE_ACCESS_HEADER_VALUE=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
OLLAMA_LOCAL_URL=
OLLAMA_ORIGIN_HOST_HEADER=

# WordPress site/admin
WP_SITE_TITLE=
WP_BLOG_DESCRIPTION=
WP_ADMIN_USERNAME=
WP_ADMIN_PASSWORD=
WP_ADMIN_EMAIL=
WP_LOCALE=
WP_GMT_OFFSET=
WP_BLOG_PUBLIC=
WP_DEBUG=

# Optional WP runtime/config
WP_PUBLIC_URL=
WP_TABLE_PREFIX=
WP_PORT=
WP_AUTH_KEY=
WP_SECURE_AUTH_KEY=
WP_LOGGED_IN_KEY=
WP_NONCE_KEY=
WP_AUTH_SALT=
WP_SECURE_AUTH_SALT=
WP_LOGGED_IN_SALT=
WP_NONCE_SALT=
WP_CONFIG_EXTRA=

# Optional MySQL aliases (legacy compatibility)
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Docker MariaDB/WordPress/phpMyAdmin stack
MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

WORDPRESS_DB_HOST=
WORDPRESS_DB_NAME=
WORDPRESS_DB_USER=
WORDPRESS_DB_PASSWORD=

SITE_PORT=
HTTP_PORT=

PMA_PORT=
PMA_HOST=
PMA_USER=
PMA_PASSWORD=

OLLAMA_PROXY_PORT=
OLLAMA_HOST_TARGET=
